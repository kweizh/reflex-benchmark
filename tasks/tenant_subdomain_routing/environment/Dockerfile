FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep \
        psmisc procps lsof unzip \
        ffmpeg libxcb-shm0 libx11-xcb1 libx11-6 libxcb1 libxext6 libxrandr2 libxcomposite1 libxcursor1 libxdamage1 libxfixes3 libxi6 libgtk-3-0t64 libpangocairo-1.0-0 libpango-1.0-0 libatk1.0-0t64 libcairo-gobject2 libcairo2 libgdk-pixbuf-2.0-0 libxrender1 libasound2t64 libfreetype6 libfontconfig1 libdbus-1-3 libnss3 libnspr4 libatk-bridge2.0-0t64 libdrm2 libxkbcommon0 libatspi2.0-0t64 libcups2t64 libxshmfence1 libgbm1 && \
    ln -s /usr/bin/python3 /usr/bin/python && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm i -g agent-browser && \
    agent-browser install && \
    curl -LsSf https://astral.sh/uv/install.sh | sh && \
    ln -s /root/.local/bin/uv /usr/local/bin/uv && \
    ln -s /root/.local/bin/uvx /usr/local/bin/uvx && \
    pip3 install --break-system-packages pytest-json-ctrf pochi-verifier requests pytest-xprocess && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user
RUN mkdir -p /home/user/myproject

LABEL Author="generate-harbor-tasks"
LABEL Description="Reflex tenant_subdomain_routing task environment: uv-managed Python for Reflex (frontend on :3000, FastAPI backend on :8000), Node.js v24, browser verification via pochi-verifier/agent-browser."

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]

# Container contents:
#   - always required apt packages: curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep
#   - process management helpers: psmisc (for `fuser`/`pkill`), procps, lsof
#   - always required pip3 packages: pytest-json-ctrf
#   - Reflex/uv: `uv` installed via Astral installer (symlinked into /usr/local/bin); Reflex itself is added by the agent inside the project with `uv add reflex`
#   - Node.js v24: required by the Reflex frontend (Next.js compilation) and by agent-browser
#   - browser verification dependencies: pochi-verifier, agent-browser, ffmpeg, and X11/GTK/CUPS/Nss libs
#   - final-state test extras: requests, pytest-xprocess
#   - /home/user/myproject: empty project directory; the agent runs `uv init` / `reflex init` inside it
